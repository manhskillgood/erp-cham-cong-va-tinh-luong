<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.ui.view" id="hr_phieu_luong_search">
        <field name="name">hr_phieu_luong.search</field>
        <field name="model">hr_phieu_luong</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="nhan_vien_id"/>
                <field name="thang"/>
                <field name="nam"/>
                <separator/>
                <filter string="Năm hiện tại" name="filter_current_year" domain="[('nam', '=', context_today().year)]"/>
                <group expand="0" string="Gom nhóm theo">
                    <filter string="Nhân viên" name="group_by_nv" context="{'group_by': 'nhan_vien_id'}"/>
                    <filter string="Tháng" name="group_by_thang" context="{'group_by': 'thang'}"/>
                    <filter string="Năm" name="group_by_nam" context="{'group_by': 'nam'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_hr_phieu_luong_tree" model="ir.ui.view">
        <field name="name">hr_phieu_luong.tree</field>
        <field name="model">hr_phieu_luong</field>
        <field name="arch" type="xml">
            <tree string="Danh sách Phiếu lương">
                <field name="name"/>
                <field name="nhan_vien_id"/>
                <field name="thang"/>
                <field name="nam"/>
                <field name="tong_gio_lam" widget="float_time" sum="Tổng giờ làm"/>
                <field name="thuc_linh" widget="monetary" sum="Tổng quỹ lương"/>
            </tree>
        </field>
    </record>

    <record id="view_hr_phieu_luong_pivot" model="ir.ui.view">
        <field name="name">hr_phieu_luong.pivot</field>
        <field name="model">hr_phieu_luong</field>
        <field name="arch" type="xml">
            <pivot string="Dashboard Lương">
                <field name="nhan_vien_id" type="row"/>
                <field name="thang" type="col"/>
                <field name="thuc_linh" type="measure"/>
                <field name="tien_phat" type="measure"/>
                <field name="tong_gio_lam" type="measure"/>
                <field name="phut_muon" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_hr_phieu_luong_graph" model="ir.ui.view">
        <field name="name">hr_phieu_luong.graph</field>
        <field name="model">hr_phieu_luong</field>
        <field name="arch" type="xml">
            <graph string="Dashboard Lương" type="bar">
                <field name="nhan_vien_id" type="row"/>
                <field name="thuc_linh" type="measure"/>
                <field name="tien_phat" type="measure"/>
            </graph>
        </field>
    </record>
    <record id="view_hr_phieu_luong_form" model="ir.ui.view">
        <field name="name">hr_phieu_luong.form</field>
        <field name="model">hr_phieu_luong</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Mã phiếu lương"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Thông tin nhân sự">
                            <field name="nhan_vien_id" options="{'no_create': True}"/>
                            <label for="thang" string="Kỳ tính lương"/>
                            <div class="o_row">
                                <field name="thang" class="oe_inline"/> /
                                <field name="nam" class="oe_inline"/>
                            </div>
                        </group>
                        <group string="Cấu hình lương">
                            <field name="luong_co_ban" widget="monetary"/>
                        </group>
                        <group string="Khấu trừ bảo hiểm">
                            <field name="bhxh" widget="monetary"/>
                            <field name="bhyt" widget="monetary"/>
                            <field name="bhtn" widget="monetary"/>
                            <field name="tong_bao_hiem" widget="monetary" style="color: red;"/>
                        </group>
                        <group string="Chính sách &amp; Thu nhập thực tế">
                            <field name="tinh_trang_ho_tro" nolabel="1" 
                                style="color: #28a745; font-weight: bold; font-size: 18px; text-align: center; display: block; margin-bottom: 10px;"/>
                            <p class="text-muted" style="font-size: 12px; font-style: italic;">
                                * Nhân viên hưởng phúc lợi: Doanh nghiệp chi trả 100% bảo hiểm bắt buộc.
                            </p>
                            <separator string="Chi tiết thu nhập theo giờ làm"/>
                            <field name="phu_cap_nhan_su" widget="monetary" string="Phụ cấp cố định (Gốc)" readonly="1"/>
                            <field name="luong_thuc_te_hien_thi" widget="monetary" string="Lương theo giờ làm"/>
                            <field name="phu_cap_thuc_te" widget="monetary" 
                                string="Phụ cấp nhận thực" 
                                style="color: #28a745; font-weight: bold;"/>
                            <p class="text-muted" style="font-size: 12px; font-style: italic;">
                                * Nhân viên nhận phụ cấp theo giờ làm việc
                            </p>
                        </group>
                    </group>
                    <notebook>
                        <page string="Chi tiết công &amp; Phạt" name="details">
                            <group>
                                <group string="Dữ liệu chấm công">
                                    <field name="tong_gio_lam" widget="float_time"/>
                                    <field name="phut_muon" decoration-danger="phut_muon > 0"/>
                                </group>
                                <group string="Tính toán tiền">
                                    <field name="tien_phat" widget="monetary" decoration-danger="tien_phat > 0"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                    <notebook>
                        <page string="Lịch sử chấm công chi tiết" name="attendance_history">
                            <field name="line_ids" readonly="1">
                                <tree xml:id="view_hr_phieu_luong_line_tree" create="0" delete="0">
                                    <field name="ngay_cham_cong"/>
                                    <field name="ca_lam"/>
                                    <field name="gio_vao" string="Giờ vào thực tế"/>
                                    <field name="gio_ra" string="Giờ ra thực tế"/>
                                    <field name="tong_gio_lam" widget="float_time" sum="Tổng cộng" string="Tổng giờ làm thực tế"/>
                                    <field name="trang_thai" widget="badge"
                                        decoration-info="trang_thai == 'di_lam'" 
                                        decoration-warning="trang_thai in ('ve_som', 'di_muon', 'di_muon_ve_som')" 
                                        decoration-danger="trang_thai == 'vang_mat'"
                                        decoration-success="trang_thai == 'vang_mat_co_phep'"/>
                                    <field name="trang_thai_duyet_don" widget="badge" string="Duyệt đơn"
                                        decoration-success="trang_thai_duyet_don == 'da_duyet'"
                                        decoration-info="trang_thai_duyet_don == 'cho_duyet'"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                    <group class="oe_subtotal_footer oe_right">
                        <field name="thuc_linh" widget="monetary" style="font-size: 1.8em; color: #7C7BAD; font-weight: bold;"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
    <record id="action_hr_phieu_luong" model="ir.actions.act_window">
        <field name="name">Phiếu Lương</field>
        <field name="res_model">hr_phieu_luong</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="hr_phieu_luong_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có phiếu lương nào được tạo.
            </p>
            <p>
                Chọn nhân viên và kỳ lương để hệ thống tự động tính toán dữ liệu từ bảng chấm công.
            </p>
        </field>
    </record>

    <record id="action_hr_phieu_luong_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard Lương</field>
        <field name="res_model">hr_phieu_luong</field>
        <field name="view_mode">pivot,graph,tree</field>
        <field name="search_view_id" ref="hr_phieu_luong_search"/>
    </record>
</odoo>