<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_tao_bang_cham_cong_wizard_form" model="ir.ui.view">
            <field name="name">cham_cong.tao_bang_cham_cong_wizard.form</field>
            <field name="model">cham_cong.tao_bang_cham_cong_wizard</field>
            <field name="arch" type="xml">
                <form string="Tạo bảng chấm công">
                    <group>
                        <field name="nhan_vien_id" options="{'no_create': True}"/>
                        <field name="tu_ngay"/>
                        <field name="den_ngay"/>
                        <field name="chi_tao_thieu"/>
                    </group>
                    <footer>
                        <button name="action_tao" type="object" string="Tạo" class="btn-primary"/>
                        <button string="Hủy" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_tao_bang_cham_cong_wizard" model="ir.actions.act_window">
            <field name="name">Tạo bảng chấm công</field>
            <field name="res_model">cham_cong.tao_bang_cham_cong_wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>
